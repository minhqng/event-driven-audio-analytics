{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audio.segment.ready.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "produced_by",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "audio.segment.ready" },
    "schema_version": { "const": "v1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "produced_by": { "type": "string" },
    "payload": {
      "type": "object",
      "required": [
        "run_id",
        "track_id",
        "segment_idx",
        "artifact_uri",
        "checksum",
        "manifest_uri",
        "sample_rate",
        "duration_s",
        "is_last_segment"
      ],
      "properties": {
        "run_id": { "type": "string" },
        "track_id": { "type": "integer" },
        "segment_idx": { "type": "integer" },
        "artifact_uri": { "type": "string" },
        "checksum": { "type": "string" },
        "manifest_uri": { "type": "string" },
        "sample_rate": { "type": "integer" },
        "duration_s": { "type": "number" },
        "is_last_segment": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
