{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audio.segment.ready.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "trace_id",
    "run_id",
    "produced_at",
    "source_service",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "audio.segment.ready" },
    "event_version": { "const": "v1" },
    "trace_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "produced_at": { "type": "string", "format": "date-time" },
    "source_service": { "const": "ingestion" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": [
        "run_id",
        "track_id",
        "segment_idx",
        "artifact_uri",
        "checksum",
        "sample_rate",
        "duration_s",
        "is_last_segment"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "track_id": { "type": "integer" },
        "segment_idx": { "type": "integer" },
        "artifact_uri": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "minLength": 1 },
        "sample_rate": { "type": "integer", "minimum": 1 },
        "duration_s": { "type": "number", "exclusiveMinimum": 0 },
        "is_last_segment": { "type": "boolean" },
        "manifest_uri": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
