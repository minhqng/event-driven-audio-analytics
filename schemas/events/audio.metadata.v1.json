{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audio.metadata.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "trace_id",
    "run_id",
    "produced_at",
    "source_service",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "audio.metadata" },
    "event_version": { "const": "v1" },
    "trace_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
    "produced_at": { "type": "string", "format": "date-time" },
    "source_service": { "const": "ingestion" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": [
        "run_id",
        "track_id",
        "artist_id",
        "genre",
        "source_audio_uri",
        "validation_status",
        "duration_s"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
        "track_id": { "type": "integer" },
        "artist_id": { "type": "integer" },
        "genre": { "type": "string", "minLength": 1 },
        "source_audio_uri": { "type": "string", "minLength": 1 },
        "validation_status": { "type": "string", "minLength": 1 },
        "duration_s": { "type": "number", "exclusiveMinimum": 0 },
        "subset": { "type": "string", "const": "small" },
        "manifest_uri": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
