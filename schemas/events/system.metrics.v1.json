{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "system.metrics.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "trace_id",
    "run_id",
    "produced_at",
    "source_service",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "system.metrics" },
    "event_version": { "const": "v1" },
    "trace_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
    "produced_at": { "type": "string", "format": "date-time" },
    "source_service": {
      "type": "string",
      "enum": ["ingestion", "processing", "writer"]
    },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "$comment": "payload.service_name must match top-level source_service; this cross-field invariant is enforced by runtime semantic validation.",
      "required": [
        "ts",
        "run_id",
        "service_name",
        "metric_name",
        "metric_value"
      ],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
        "service_name": { "type": "string", "minLength": 1 },
        "metric_name": { "type": "string", "minLength": 1 },
        "metric_value": { "type": "number" },
        "labels_json": { "type": "object" },
        "unit": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
