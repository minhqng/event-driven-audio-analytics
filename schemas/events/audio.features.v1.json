{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audio.features.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "trace_id",
    "run_id",
    "produced_at",
    "source_service",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "audio.features" },
    "event_version": { "const": "v1" },
    "trace_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
    "produced_at": { "type": "string", "format": "date-time" },
    "source_service": { "const": "processing" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": [
        "ts",
        "run_id",
        "track_id",
        "segment_idx",
        "artifact_uri",
        "checksum",
        "rms",
        "silent_flag",
        "mel_bins",
        "mel_frames",
        "processing_ms"
      ],
      "properties": {
        "ts": { "type": "string", "format": "date-time" },
        "run_id": { "type": "string", "minLength": 1, "pattern": "^(?!\\.{1,2}$)[^\\s/\\\\:]+$" },
        "track_id": { "type": "integer" },
        "segment_idx": { "type": "integer" },
        "artifact_uri": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "minLength": 1 },
        "rms": { "type": "number" },
        "silent_flag": { "type": "boolean" },
        "mel_bins": { "type": "integer", "minimum": 1 },
        "mel_frames": { "type": "integer", "minimum": 1 },
        "processing_ms": { "type": "number", "minimum": 0 },
        "manifest_uri": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
