{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/envelope.v1.json",
  "title": "Event Envelope v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "produced_by",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
