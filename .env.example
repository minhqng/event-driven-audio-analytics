COMPOSE_PROJECT_NAME=event-driven-audio-analytics
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NODE_ID=1
KAFKA_BROKER_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_CONTROLLER_PORT=9093
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
POSTGRES_DB=audio_analytics
POSTGRES_USER=audio_analytics
POSTGRES_PASSWORD=audio_analytics
TIMESCALEDB_PORT=5432
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ARTIFACTS_ROOT=/app/artifacts
RUN_ID=demo-run
LOG_LEVEL=INFO
STORAGE_BACKEND=local
# Leave MINIO_ENDPOINT_URL unset unless you need to override the default host or scheme.
# When unset, the services derive http://minio:9000 for MINIO_SECURE=false and
# https://minio:9000 for MINIO_SECURE=true.
# MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET=fma-small-artifacts
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_SECURE=false
MINIO_CREATE_BUCKET=false
# Optional compatibility aliases for prompt-driven naming
# MINIO_ENDPOINT=http://minio:9000
# ARTIFACT_BUCKET=fma-small-artifacts
LOCAL_FMA_METADATA_CSV=/app/data/local/fma_metadata/tracks.csv
LOCAL_FMA_AUDIO_ROOT=/app/data/local/fma_small
PROCESSING_CONSUMER_GROUP=event-driven-audio-analytics-processing
PROCESSING_AUTO_OFFSET_RESET=earliest
PROCESSING_POLL_TIMEOUT_S=1.0
PROCESSING_SESSION_TIMEOUT_MS=45000
PROCESSING_MAX_POLL_INTERVAL_MS=300000
PROCESSING_CONSUMER_RETRY_BACKOFF_MS=250
PROCESSING_CONSUMER_RETRY_BACKOFF_MAX_MS=5000
PROCESSING_ARTIFACT_RETRY_ATTEMPTS=5
PROCESSING_ARTIFACT_RETRY_BACKOFF_MS=250
PROCESSING_ARTIFACT_RETRY_BACKOFF_MAX_MS=5000
# Enable only when STORAGE_BACKEND=local but the processing service must fail fast
# if historical s3:// claim-check replay is unavailable.
PROCESSING_PROBE_S3_REPLAY_READINESS=false
WRITER_CONSUMER_GROUP=event-driven-audio-analytics-writer
WRITER_AUTO_OFFSET_RESET=earliest
WRITER_POLL_TIMEOUT_S=1.0
WRITER_SESSION_TIMEOUT_MS=45000
WRITER_MAX_POLL_INTERVAL_MS=300000
WRITER_CONSUMER_RETRY_BACKOFF_MS=250
WRITER_CONSUMER_RETRY_BACKOFF_MAX_MS=5000
WRITER_DB_POOL_MIN_SIZE=1
WRITER_DB_POOL_MAX_SIZE=4
WRITER_DB_POOL_TIMEOUT_S=30.0
KAFKA_PRODUCER_RETRIES=10
KAFKA_PRODUCER_RETRY_BACKOFF_MS=250
KAFKA_PRODUCER_RETRY_BACKOFF_MAX_MS=5000
KAFKA_PRODUCER_DELIVERY_TIMEOUT_MS=120000
EVAL_RESOURCE_SAMPLE_INTERVAL_S=2
EVAL_ARTIFACT_READ_SAMPLE_SIZE=20
EVAL_ENABLE_FULL_FMA_SMALL=false
