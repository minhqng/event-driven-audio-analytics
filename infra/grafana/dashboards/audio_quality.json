      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, $__interval),\n  run_id AS metric,\n  ROUND(AVG(rms)::numeric, 3) AS value\nFROM audio_features\nWHERE $__timeFilter(ts)\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Segment RMS Over Time",
      "type": "timeseries"
