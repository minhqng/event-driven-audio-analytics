          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(ts, $__interval),\n  COALESCE(topic_name, 'unknown') AS metric,\n  ROUND(AVG(metric_value)::numeric, 3) AS value\nFROM vw_dashboard_metric_events\nWHERE $__timeFilter(ts)\n  AND service_name = 'writer'\n  AND metric_name = 'write_ms'\n  AND metric_status = 'ok'\nGROUP BY 1, 2\nORDER BY 1, 2;",
